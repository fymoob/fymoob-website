{
  "mcpServers": {
    "gsc": {
      "command": "c:\\Users\\Vine\\mcp-gsc\\.venv\\Scripts\\python.exe",
      "args": ["c:\\Users\\Vine\\mcp-gsc\\gsc_server.py"],
      "env": {
        "GSC_OAUTH_CLIENT_SECRETS_FILE": "c:\\Users\\Vine\\mcp-gsc\\client_secrets.json",
        "GSC_DATA_STATE": "all"
      }
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "@playwright/mcp@latest"]
    },
    "brave-search": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@brave/brave-search-mcp-server"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "perplexity": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    }
  }
}
