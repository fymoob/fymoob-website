        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qiE '(curl|wget|fetch|http).*(DELETE|PUT|PATCH).*(vistahost|loft)' && echo '{\"decision\":\"block\",\"reason\":\"BLOCKED: Destructive API call to Loft/Vista detected. Read-only access only.\"}' && exit 1 || true",
