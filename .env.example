LOFT_API_KEY=
NEXT_PUBLIC_SITE_URL=https://fymoob.com.br
NHOST_SUBDOMAIN=ppbxdsyojwqujdrmnxdv

# ─────────────────────────────────────────────────────
# Admin panel (see docs/admin-panel-setup.md)
# ─────────────────────────────────────────────────────

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# CSV of admin emails (case-insensitive). Only these can request magic links.
ALLOWED_ADMIN_EMAILS=

# Resend (email delivery) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@fymoob.com.br

# Upstash Redis (rate limit) — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────
# Sanity CMS — Studio em /studio (ver docs/architecture/sanity-setup-guide.md)
# ─────────────────────────────────────────────────────

# Project ID do Sanity (criar em sanity.io e copiar da página do projeto)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset (padrão "production"). Não mudar a menos que haja motivo
NEXT_PUBLIC_SANITY_DATASET=production

# API version — fixar em data ISO (Sanity usa pinning de versão)
SANITY_API_VERSION=2026-04-25

# Token API pra leitura de drafts (preview). Criar em manage.sanity.io
# Permissões: Viewer (read-only). Não exposer no client.
SANITY_API_READ_TOKEN=

# Token API pra revalidação on-demand (webhook). Criar em manage.sanity.io
# Permissões: Editor. Webhook envia secret pra /api/revalidate-blog
SANITY_REVALIDATE_SECRET=
