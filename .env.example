LOFT_API_KEY=
# Default: produção (brunoces-rest). Em dev/staging, alternar pra:
# LOFT_API_BASE_URL=https://sandbox-rest.vistahost.com.br
# CLAUDE.md exige testes em sandbox antes de prod.
LOFT_API_BASE_URL=
NEXT_PUBLIC_SITE_URL=https://fymoob.com.br
NHOST_SUBDOMAIN=ppbxdsyojwqujdrmnxdv

# ─────────────────────────────────────────────────────
# Admin panel (see docs/admin-panel-setup.md)
# ─────────────────────────────────────────────────────

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# CSV of admin emails (case-insensitive). Only these can request magic links.
ALLOWED_ADMIN_EMAILS=

# Resend (email delivery) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@fymoob.com.br

# Upstash Redis (rate limit) — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────
# Supabase — Custom Blog Admin (Fase 18). Ver supabase/README.md
# ─────────────────────────────────────────────────────

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — leitura via RLS (somente artigos publicados)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypassa RLS. SOMENTE server-side. Não expor no client.
SUPABASE_SERVICE_ROLE_KEY=

# Toggle de fonte do blog público:
#   - "supabase": le do Supabase (Fase 18, requer migracao 18.G)
#   - qualquer outro valor / vazio: comportamento legado (Sanity + MDX fallback)
# Default: vazio (legado). Mudar pra "supabase" apos cutover validado.
BLOG_SOURCE=

# Cron secret pra Vercel chamar /api/cron/publish-scheduled
# Gerar com: openssl rand -base64 32
# Em prod, configurar na Vercel; em dev nao precisa (sem secret = cron desligado).
CRON_SECRET=

# ─────────────────────────────────────────────────────
# Analytics Intelligence (Sprint 1 Linha A — skill weekly-report)
# Setup completo: docs/analytics/intel-setup.md
# ─────────────────────────────────────────────────────

# Service account JSON (compartilhado entre GSC + GA4 — mesmo Google Cloud project).
# 1. Google Cloud Console: criar service account
# 2. Habilitar APIs: Search Console API + Google Analytics Data API
# 3. Adicionar como user em GSC (Settings > Users) com role "Restricted"
# 4. Adicionar como user em GA4 (Property Access Management) com role "Viewer"
# 5. Colar o JSON inteiro aqui entre aspas simples (preserve quebras de linha)
GOOGLE_SERVICE_ACCOUNT_JSON=

# GSC site URL (formato exato do GSC: domain property usa "sc-domain:")
GSC_SITE_URL=sc-domain:fymoob.com.br

# GA4 property ID — GA4 Admin > Property Settings > Property ID (numerico)
GA4_PROPERTY_ID=
