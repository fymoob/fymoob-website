LOFT_API_KEY=
NEXT_PUBLIC_SITE_URL=https://fymoob.com
NHOST_SUBDOMAIN=ppbxdsyojwqujdrmnxdv

# ─────────────────────────────────────────────────────
# Admin panel (see docs/admin-panel-setup.md)
# ─────────────────────────────────────────────────────

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# CSV of admin emails (case-insensitive). Only these can request magic links.
ALLOWED_ADMIN_EMAILS=

# Resend (email delivery) — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@fymoob.com

# Upstash Redis (rate limit) — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
